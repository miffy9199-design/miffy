<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>農場守護者：極端氣候大挑戰</title>
    <style>
        :root {
            --primary-color: #2e7d32;
            --secondary-color: #4caf50;
            --background-color: #f1f8e9;
            --text-color: #333;
            --card-bg: #ffffff;
        }

        * {
            box-sizing: border-box;
            font-family: "Helvetica Neue", Arial, "Noto Sans TC", sans-serif;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--background-color);
            color: var(--text-color);
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .game-container {
            background: var(--card-bg);
            border-radius: 16px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
            max-width: 600px;
            width: 100%;
            padding: 30px;
            text-align: center;
            overflow: hidden;
        }

        h1 {
            color: var(--primary-color);
            margin-bottom: 15px;
            font-size: 24px;
        }

        h2 {
            color: #555;
            margin-bottom: 20px;
            font-size: 18px;
        }

        .status-bar {
            display: flex;
            justify-content: space-between;
            background: #e8f5e9;
            padding: 10px 20px;
            border-radius: 8px;
            margin-bottom: 25px;
            font-weight: bold;
            font-size: 16px;
        }

        .score-val {
            color: #d84315;
        }

        /* 遊戲各階段畫面切換 */
        .screen {
            display: none;
            animation: fadeIn 0.5s ease-in-out forwards;
        }

        .screen.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .story-text, .question-text {
            font-size: 18px;
            line-height: 1.6;
            margin-bottom: 25px;
            text-align: left;
            background: #fafafa;
            padding: 15px;
            border-left: 5px solid var(--primary-color);
            border-radius: 4px;
        }

        /* 按鈕樣式 */
        .btn {
            background-color: var(--primary-color);
            color: white;
            border: none;
            padding: 12px 28px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 25px;
            cursor: pointer;
            transition: all 0.2s ease;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            width: 100%;
            margin-bottom: 12px;
        }

        .btn:hover {
            background-color: var(--secondary-color);
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }

        .btn:active {
            transform: translateY(0);
        }

        .options-container {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* 反饋提示 (正確/錯誤) */
        .feedback {
            font-size: 20px;
            font-weight: bold;
            margin: 20px 0;
            padding: 10px;
            border-radius: 8px;
            display: none;
        }

        .feedback.correct {
            display: block;
            background-color: #d4edda;
            color: #155724;
        }

        .feedback.wrong {
            display: block;
            background-color: #f8d7da;
            color: #721c24;
        }

        /* 圖鑑標籤 */
        .badge {
            display: inline-block;
            background: #ffe0b2;
            color: #e65100;
            padding: 5px 12px;
            border-radius: 15px;
            margin: 5px;
            font-size: 14px;
            font-weight: bold;
        }

        /* 輪盤動畫效果 */
        .wheel-anim {
            font-size: 48px;
            margin: 20px 0;
            display: none;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        .prize-result {
            font-size: 22px;
            color: #e65100;
            font-weight: bold;
            margin-top: 20px;
            padding: 15px;
            border: 2px dashed #e65100;
            background: #fff3e0;
            border-radius: 8px;
            display: none;
        }
    </style>
</head>
<body>

<div class="game-container">
    <div class="status-bar">
        <div>💰 金幣：<span id="global-coins" class="score-val">0</span></div>
        <div>🌾 關卡：<span id="stage-title">準備中</span></div>
    </div>

    <div id="screen-start" class="screen active">
        <h1>🌾 農場守護者：極端氣候大挑戰</h1>
        <h2>使命召喚</h2>
        <div class="story-text">
            ⚠️ 氣候異常導致全球農作物面臨前所未有的危機！<br><br>
            歡迎你，你是被選中的農場守護者。你的任務：透過專業知識拯救農場，並學習核心的農業與營養學技能！
        </div>
        <button class="btn" onclick="startGame()">進入農場挑戰</button>
    </div>

    <div id="screen-quiz" class="screen">
        <h1 id="quiz-title">第一關：天氣與澆水</h1>
        <div class="question-text" id="question-box">題目載入中...</div>
        
        <div class="options-container" id="options-box">
            </div>

        <div id="feedback" class="feedback"></div>
        <button class="btn" id="btn-next" style="display:none;" onclick="nextQuestion()">下一題</button>
    </div>

    <div id="screen-result" class="screen">
        <h1>📊 挑戰結束報告</h1>
        <div class="story-text" style="text-align: center;">
            <p style="font-size: 20px; margin-bottom: 10px;">最終獲得金幣：<strong id="final-coins" class="score-val">0</strong></p>
            <p style="font-size: 22px; color: #2e7d32; font-weight: bold; margin-bottom: 20px;">榮獲職稱：<span id="final-title">--</span></p>
            <hr style="margin: 15px 0; border: 0; border-top: 1px solid #ccc;">
            <p style="text-align: left; font-weight: bold; margin-bottom: 10px;">🔓 已解鎖蔬菜圖鑑：</p>
            <div id="collection-box" style="text-align: left;">
                </div>
        </div>
        <button class="btn" id="btn-go-draw" onclick="checkDrawEligibility()">前往幸運抽獎</button>
    </div>

    <div id="screen-lottery" class="screen">
        <h1>🎁 幸運大抽獎</h1>
        <div class="story-text" id="lottery-msg" style="text-align: center;">
            </div>
        
        <div id="wheel" class="wheel-anim">🎡</div>
        <div id="prize-display" class="prize-result"></div>

        <button class="btn" id="btn-spin" onclick="startDraw()">轉動幸運輪盤</button>
        <button class="btn" style="background-color: #555; margin-top: 10px;" onclick="restartGame()">重新挑戰</button>
    </div>
</div>

<script>
    // --- 遊戲資料庫 ---
    const stage1_questions = [
        { q: "連續一週高溫38°C且強光曝曬", options: ["要", "不要"], a: "要", key: "抗旱灌溉法" },
        { q: "午後雷陣雨，累積降雨量已達50mm", options: ["要", "不要"], a: "不要", key: "防澇排水技術" },
        { q: "鋒面過境，陰天且空氣濕度高達95%", options: ["要", "不要"], a: "不要", key: "高濕度控水學" },
        { q: "颱風來襲前夕，焚風大作、土壤水分蒸發極快", options: ["要", "不要"], a: "要", key: "焚風緊急灌溉" },
        { q: "秋季微風多雲，土壤表面微乾但底層仍濕潤", options: ["要", "不要"], a: "不要", key: "深層土壤水分觀測" }
    ];

    const stage2_questions = [
        { q: "我們常吃的「胡蘿蔔（紅蘿蔔）」在植物學上是屬於哪個部位？", options: ["A. 果實", "B. 肉質直根", "C. 地下莖"], a: "B", key: "胡蘿蔔(肉質直根)" },
        { q: "哪種蔬菜在栽培時需要進行「培土」（將土堆高包裹莖部）以避免變綠變苦？", options: ["A. 韭黃與白蘿蔔", "B. 地瓜葉", "C. 菠菜"], a: "A", key: "軟化栽培(培土技術)" },
        { q: "高麗菜與大白菜結球（一層一層包起來）主要是為了應對什麼？", options: ["A. 適應高溫", "B. 防止害蟲", "C. 儲藏營養與禦寒"], a: "C", key: "結球葉菜禦寒機制" },
        { q: "山藥與白蘿蔔雖然外觀有些相似，但山藥在植物分類上主要屬於？", options: ["A. 塊莖", "B. 肉質根", "C. 葉菜類"], a: "A", key: "山藥(塊莖植物)" },
        { q: "花椰菜（綠色花朵狀）我們主要食用的部位其實是？", options: ["A. 發育未完全的花蕾與花莖", "B. 成熟的果實", "C. 突變的葉片"], a: "A", key: "花椰菜(花蕾與花莖)" }
    ];

    const stage3_questions = [
        { q: "菠菜富含鐵質，但因為含有哪種成分會影響人體對鐵和鈣的吸收，建議烹調時先汆燙？", options: ["A. 草酸", "B. 檸檬酸", "C. 醋酸"], a: "A", key: "草酸(汆燙去苦)" },
        { q: "「胡蘿蔔（紅蘿蔔）」富含β-胡蘿蔔素，屬於脂溶性維生素，用哪種烹調方式人體吸收率最高？", options: ["A. 生吃涼拌", "B. 搭配油脂熱炒", "C. 純水清蒸"], a: "B", key: "脂溶性胡蘿蔔素吸收法" },
        { q: "牛奶除了富含鈣質，還含有哪種能促進鈣質吸收的關鍵維生素？", options: ["A. 維生素C", "B. 維生素D", "C. 維生素E"], a: "B", key: "維生素D促進鈣吸收" },
        { q: "雞蛋所含的蛋白質被稱為「全營養蛋白質」，主要是因為它？", options: ["A. 包含人體無法自行合成的所有必需胺基酸", "B. 熱量極低", "C. 完全不含脂肪"], a: "A", key: "雞蛋必需胺基酸" },
        { q: "膳食纖維分為水溶性與非水溶性，燕麥和秋葵中黏黏的成分主要能幫助什麼？", options: ["A. 增加肌肉", "B. 延緩血糖上升與降低膽固醇", "C. 快速補充身體熱量"], a: "B", key: "水溶性膳食纖維效益" }
    ];

    // --- 遊戲狀態變數 ---
    let farm_coins = 0;
    let collection = [];
    let currentStage = 1; 
    let stageQuestions = [];
    let questionIndex = 0;

    // --- 輔助函式：從陣列中隨機抽取 N 個元素 ---
    function getRandomSample(arr, n) {
        let shuffled = [...arr].sort(() => 0.5 - Math.random());
        return shuffled.slice(0, n);
    }

    // --- 畫面切換控制 ---
    function showScreen(screenId) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(screenId).classList.add('active');
    }

    // --- 開始遊戲 ---
    function startGame() {
        farm_coins = 0;
        collection = [];
        currentStage = 1;
        document.getElementById('global-coins').innerText = farm_coins;
        initStage();
    }

    // --- 初始化關卡 ---
    function initStage() {
        questionIndex = 0;
        if (currentStage === 1) {
            document.getElementById('stage-title').innerText = "第一關";
            document.getElementById('quiz-title').innerText = "第一關：天氣與澆水 (進階專家版)";
            stageQuestions = getRandomSample(stage1_questions, 3);
        } else if (currentStage === 2) {
            document.getElementById('stage-title').innerText = "第二關";
            document.getElementById('quiz-title').innerText = "第二關：蔬菜辨識與植物學 (植物學專家版)";
            stageQuestions = getRandomSample(stage2_questions, 3);
        } else if (currentStage === 3) {
            document.getElementById('stage-title').innerText = "第三關";
            document.getElementById('quiz-title').innerText = "第三關：精準營養知識 (營養師級別)";
            stageQuestions = getRandomSample(stage3_questions, 3);
        } else {
            endGame();
            return;
        }
        showScreen('screen-quiz');
        showQuestion();
    }

    // --- 顯示題目 ---
    function showQuestion() {
        let qData = stageQuestions[questionIndex];
        document.getElementById('question-box').innerHTML = currentStage === 1 ? `<strong>氣候觀測：</strong>${qData.q}` : `<strong>專業學科提示：</strong>${qData.q}`;
        
        let optionsBox = document.getElementById('options-box');
        optionsBox.innerHTML = "";
        document.getElementById('feedback').className = "feedback";
        document.getElementById('btn-next').style.display = "none";

        qData.options.forEach(opt => {
            let btn = document.createElement('button');
            btn.className = "btn";
            btn.style.backgroundColor = "#fff";
            btn.style.color = "#333";
            btn.style.border = "2px solid #2e7d32";
            btn.innerText = opt;
            btn.onclick = () => checkAnswer(opt, qData, btn);
            optionsBox.appendChild(btn);
        });
    }

    // --- 檢查答案 ---
    function checkAnswer(selectedOpt, qData, clickedBtn) {
        // 停用所有選項按鈕，防止重複點擊
        let buttons = document.getElementById('options-box').querySelectorAll('button');
        buttons.forEach(b => b.disabled = true);

        // 擷取乾淨的答案字元 (例如將 "A. 果實" 轉為 "A")
        let userAns = selectedOpt;
        if (currentStage > 1) {
            userAns = selectedOpt.charAt(0);
        }

        let feedback = document.getElementById('feedback');
        
        if (userAns === qData.a) {
            feedback.innerText = "✔ 正確！金幣 +10";
            feedback.className = "feedback correct";
            farm_coins += 10;
            document.getElementById('global-coins').innerText = farm_coins;
            clickedBtn.style.backgroundColor = "#c8e6c9";
            
            // 第二關答對才加圖鑑
            if (currentStage === 2) {
                collection.push(qData.key);
            }
        } else {
            feedback.innerText = `✘ 錯誤！正確答案是：${qData.a}`;
            feedback.className = "feedback wrong";
            clickedBtn.style.backgroundColor = "#ffcdd2";
        }

        document.getElementById('btn-next').style.display = "block";
    }

    // --- 下一題或下一關 ---
    function nextQuestion() {
        questionIndex++;
        if (questionIndex < stageQuestions.length) {
            showQuestion();
        } else {
            currentStage++;
            initStage();
        }
    }

    // --- 遊戲結束結算 ---
    function endGame() {
        document.getElementById('stage-title').innerText = "結算";
        document.getElementById('final-coins').innerText = farm_coins;

        // 計算職稱
        let title = "";
        if (farm_coins >= 80) title = "國家級農業院士";
        else if (farm_coins >= 60) title = "資深專業農學專家";
        else if (farm_coins >= 30) title = "新進農業研究員";
        else title = "實習小農夫";
        document.getElementById('final-title').innerText = title;

        // 渲染圖鑑
        let colBox = document.getElementById('collection-box');
        colBox.innerHTML = "";
        if (collection.length === 0) {
            colBox.innerHTML = "<span style='color:gray;'>本次挑戰未解鎖任何植物學圖鑑。</span>";
        } else {
            collection.forEach(item => {
                let span = document.createElement('span');
                span.className = "badge";
                span.innerText = `📖 ${item}`;
                colBox.appendChild(span);
            });
        }

        showScreen('screen-result');
    }

    // --- 檢查抽獎資格 ---
    function checkDrawEligibility() {
        showScreen('screen-lottery');
        let msgBox = document.getElementById('lottery-msg');
        let btnSpin = document.getElementById('btn-spin');
        
        // 隱藏上一次的結果
        document.getElementById('prize-display').style.display = "none";

        if (farm_coins < 50) {
            msgBox.innerHTML = `⚠️ 很抱歉！您目前只有 <strong class="score-val">${farm_coins}</strong> 金幣，不足 50 金幣，無法參與本次抽獎活動。<br><br>請多充實農業知識，下次再來挑戰吧！`;
            btnSpin.style.display = "none";
        } else {
            msgBox.innerHTML = `🎉 恭喜你獲得 <strong class="score-val">${farm_coins}</strong> 金幣，成功解鎖抽獎資格！<br>準備好測試今日的幸運指數了嗎？`;
            btnSpin.style.display = "block";
        }
    }

    // --- 進行抽獎 ---
    function startDraw() {
        let btnSpin = document.getElementById('btn-spin');
        let wheel = document.getElementById('wheel');
        let prizeDisplay = document.getElementById('prize-display');

        btnSpin.disabled = true;
        prizeDisplay.style.display = "none";
        wheel.style.display = "block"; // 開始轉動

        setTimeout(() => {
            wheel.style.display = "none"; // 停止轉動
            
            // 1 ~ 100 隨機機率判定
            let draw = Math.floor(Math.random() * 100) + 1;
            let prizeText = "";

            if (draw <= 5) {
                prizeText = "🎁 [超級大獎] !!! 小農市集 500 元購物金！";
            } else if (draw <= 20) {
                prizeText = "⚡ [金幣加倍卡] !! 下一關金幣 x3 倍 !!";
            } else if (draw <= 45) {
                prizeText = "💰 [金幣獎勵] ! +20 小農金幣！";
            } else if (draw <= 75) {
                prizeText = "📖 [學習獎勵] 蔬菜圖鑑解鎖卡（解鎖一種蔬菜知識）";
            } else {
                prizeText = "🍎 [健康小知識] : 多吃蔬菜有益身體！下次運氣一定更好！";
            }

            prizeDisplay.innerText = prizeText;
            prizeDisplay.style.display = "block";
            btnSpin.disabled = false;
        }, 1200); // 模擬轉動 1.2 秒
    }

    // --- 重新遊戲 ---
    function restartGame() {
        showScreen('screen-start');
        document.getElementById('stage-title').innerText = "準備中";
    }
</script>

</body>
</html>
